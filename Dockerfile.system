# syntax=docker/dockerfile:1
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1

WORKDIR /app

# Install system dependencies including ta-lib build requirements
RUN apt-get update && apt-get install -y --no-install-recommends \
      curl ca-certificates git \
      build-essential gcc g++ make \
      wget \
      automake libtool autoconf \
    && rm -rf /var/lib/apt/lists/*

# Install TA-Lib C library
ARG TALIB_VERSION=0.4.0
RUN wget -q http://prdownloads.sourceforge.net/ta-lib/ta-lib-${TALIB_VERSION}-src.tar.gz \
      -O /tmp/ta-lib.tar.gz && \
    tar -xzf /tmp/ta-lib.tar.gz -C /tmp && \
    cd /tmp/ta-lib && \
    ./configure --prefix=/usr && \
    make && \
    make install && \
    ldconfig && \
    cd / && \
    rm -rf /tmp/ta-lib /tmp/ta-lib.tar.gz


COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY . /app

EXPOSE 8000 8001 8002 8003 8004 8005 8006

CMD ["python", "-m", "start_full_system"]
